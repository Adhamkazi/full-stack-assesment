{
  "name": "food-delivery-backend",
  "version": "1.0.0",
  "description": "Food Delivery REST API - Express + TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
